      { "francais": "Il n'est pas là", "libanais": "Mou hon", "phonetique": "mou hon" },
      { "francais": "Ce n'est pas bon", "libanais": "Mou mnih", "phonetique": "mou mnih" }
    ]
  },
  {
    "id": "present",
    "titre": "Le présent",
    "explication": "Au présent, on ajoute 'b' au début du verbe. Pour dire 'je suis en train de faire', on ajoute '3am' avant.",
